# =============================================================================
# RegPulse Environment Variables
# Copy this file to .env and fill in actual values
# =============================================================================

# --- Database ---
POSTGRES_USER=regpulse
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=regpulse
DATABASE_URL=postgresql+asyncpg://regpulse:your-secure-password-here@localhost:5432/regpulse

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication (RS256 key pair) ---
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=your-rsa-private-key-pem
JWT_PUBLIC_KEY=your-rsa-public-key-pem
JWT_BLACKLIST_TTL=3600

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- LLM models ---
# LLM_MODEL: primary, called via the Anthropic client. Must be a Claude
#   model id (the code passes `thinking={...}` which only Anthropic supports).
# LLM_FALLBACK_MODEL: fallback, called via the OpenAI client when the
#   primary fails. MUST be an OpenAI-compatible model id (e.g. gpt-4o,
#   gpt-4o-mini). Setting this to a Claude id will crash on the fallback
#   path with "model not found" — config.model_post_init asserts this.
# LLM_SUMMARY_MODEL: AI summary worker, called via the Anthropic client.
LLM_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o
LLM_SUMMARY_MODEL=claude-haiku-4-5-20251001

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072

# --- RAG tuning ---
RAG_COSINE_THRESHOLD=0.4
RAG_TOP_K_INITIAL=12
RAG_TOP_K_FINAL=6
RAG_MAX_CHUNKS_PER_DOC=2

# --- Razorpay (payments) ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- SMTP (email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=noreply@regpulse.in

# --- Admin ---
# Comma-separated list of email addresses allowed to be admins
ADMIN_EMAIL_ALLOWLIST=admin@yourcompany.com

# --- Application ---
FREE_CREDIT_GRANT=5
MAX_QUESTION_CHARS=500
FRONTEND_URL=http://localhost:3000
# Sprint 3: public base URL used for share links + OG metadata
PUBLIC_BASE_URL=http://localhost:3000
# Sprint 3: backend public URL — must be reachable by LinkedIn/X for OG image fetches
BACKEND_PUBLIC_URL=http://localhost:8000
ENVIRONMENT=dev

# --- Sprint 3: Knowledge Graph ---
KG_EXTRACTION_ENABLED=true
RAG_KG_EXPANSION_ENABLED=false
RAG_KG_BOOST_WEIGHT=0.1

# --- Sprint 3: News ingest ---
RSS_INGEST_ENABLED=true
RSS_SOURCES=RBI_PRESS,BUSINESS_STANDARD,LIVEMINT,ET_BANKING
NEWS_RELEVANCE_THRESHOLD=0.75

# --- Sprint 3: Public snippets ---
SNIPPET_RATE_LIMIT_PER_MIN=60
SNIPPET_EXPIRY_DAYS=90

# --- Demo mode (set to true for local development with mock OTP) ---
# IMPORTANT: DEMO_MODE=true is blocked when ENVIRONMENT=prod
DEMO_MODE=false

# --- Observability ---
SENTRY_DSN=
# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Jira (project management) ---
JIRA_BASE_URL=https://thinkin.atlassian.net
JIRA_EMAIL=amit.das@think360.ai
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=RP
