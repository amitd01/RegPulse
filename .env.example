# =============================================================================
# RegPulse Environment Variables
# Copy this file to .env and fill in actual values
# =============================================================================

# --- Database ---
POSTGRES_USER=regpulse
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=regpulse
DATABASE_URL=postgresql+asyncpg://regpulse:your-secure-password-here@localhost:5432/regpulse

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication (RS256 key pair) ---
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=your-rsa-private-key-pem
JWT_PUBLIC_KEY=your-rsa-public-key-pem
JWT_BLACKLIST_TTL=3600

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- LLM models ---
LLM_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o
LLM_SUMMARY_MODEL=claude-haiku-4-5-20251001

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072

# --- RAG tuning ---
RAG_COSINE_THRESHOLD=0.4
RAG_TOP_K_INITIAL=12
RAG_TOP_K_FINAL=6
RAG_MAX_CHUNKS_PER_DOC=2

# --- Razorpay (payments) ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- SMTP (email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=noreply@regpulse.in

# --- Admin ---
# Comma-separated list of email addresses allowed to be admins
ADMIN_EMAIL_ALLOWLIST=admin@yourcompany.com

# --- Application ---
FREE_CREDIT_GRANT=5
MAX_QUESTION_CHARS=500
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=dev

# --- Demo mode (set to true for local development with mock OTP) ---
# IMPORTANT: DEMO_MODE=true is blocked when ENVIRONMENT=prod
DEMO_MODE=false

# --- Observability ---
SENTRY_DSN=

# --- Jira (project management) ---
JIRA_BASE_URL=https://thinkin.atlassian.net
JIRA_EMAIL=amit.das@think360.ai
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=RP
